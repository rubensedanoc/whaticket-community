# ============================================
# Dockerfile para desarrollo con Meta WhatsApp API
# Optimizado para Mac M2 - Sin dependencias de Chrome/Puppeteer
# ============================================

FROM node:20-slim

# Instalar solo dependencias básicas necesarias
RUN apt-get update && apt-get install -y \
    wget \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app

# Copiar package files e instalar dependencias
COPY package*.json ./
RUN npm install --legacy-peer-deps

# Copiar código fuente y compilar
COPY . .
RUN npm run build --legacy-peer-deps

# Variables de entorno
ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

# Iniciar aplicación (espera 10 segundos para que MySQL esté listo)
CMD sleep 10 && npx sequelize db:migrate && node dist/server.js
