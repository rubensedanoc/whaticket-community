NODE_ENV=
BACKEND_URL=http://localhost
FRONTEND_URL=http://localhost:3000
PROXY_PORT=8080
PORT=8080

# Storage media: "S3" (o "s3") para usar S3, vacío/local para guardar en ./public
STORAGE_TYPE=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Opcional para MinIO/Cloudflare R2 u otros endpoints compatibles S3
S3_ENDPOINT_URL=
# Prefijo opcional dentro del bucket (ej: whaticket/prod)
S3_BACKUP_PREFIX=

DB_DIALECT=
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

JWT_SECRET=
JWT_REFRESH_SECRET=


# Feature flag para skip WhatsApp initialization
SKIP_WHATSAPP_INIT=true

# ===================================
# META API (WhatsApp Business API)
# ===================================

# Versión de la API de Meta (ej: v18.0, v19.0)
META_API_VERSION=v22.0

# URL base de la API de Meta Graph
META_API_BASE_URL=https://graph.facebook.com

# Token de verificación para el webhook de Meta
WEBHOOK_VERIFY_TOKEN=

META_INITIAL_TEMPLATE_NAME = reengagement_message
META_REENGAGEMENT_TEMPLATE_NAME = reengagement_message

# Variables para el bot de inactividad
ENABLE_PROACTIVE_BOT_REPORTING=false
EXTERNAL_API_RESULT_URL=https://webhook.site/7d7d4118-e0ab-45bf-93e7-8c319a5eb8d3
PROACTIVE_BOT_SEND_DELAY_MS=200
PROACTIVE_BOT_TEMPLATE_NAME=encuesta_inactividad

# Billing Incidencias - Sistema externo de registro de incidencias
BILLING_INCIDENCIA_BASE_URL=http://incidencias.restaurant.pe/billing/slave/rest/incidenciacliente
BILLING_INCIDENCIA_TIMEOUT_MS=15000
BILLING_WEBHOOK_API_KEY = restpe-2026!-!
BILLING_INCIDENCIA_TEST_MODE=true

