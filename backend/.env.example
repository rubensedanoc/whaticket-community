NODE_ENV=
BACKEND_URL=http://localhost
FRONTEND_URL=http://localhost:3000
PROXY_PORT=8080
PORT=8080

# Storage media: "S3" (o "s3") para usar S3, vacío/local para guardar en ./public
STORAGE_TYPE=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Opcional para MinIO/Cloudflare R2 u otros endpoints compatibles S3
S3_ENDPOINT_URL=
# Prefijo opcional dentro del bucket (ej: whaticket/prod)
S3_BACKUP_PREFIX=

DB_DIALECT=
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

JWT_SECRET=
JWT_REFRESH_SECRET=

# Versión de la API de Meta (ej: v18.0, v19.0)
META_API_VERSION=v18.0

# URL base de la API de Meta Graph
META_API_BASE_URL=https://graph.facebook.com

# App Secret de la aplicación de Meta (se obtiene en Meta Developer Console)
# Usado para validar firmas de webhook (X-Hub-Signature-256)
META_APP_SECRET=

# Token de verificación para el webhook de Meta
# Debe coincidir con el configurado en Meta Developer Console
WEBHOOK_VERIFY_TOKEN=

# ID del número de teléfono de WhatsApp Business (se obtiene en Meta Developer Console)
META_PHONE_NUMBER_ID=

# Access Token de Meta (System User Token o User Access Token)
META_ACCESS_TOKEN=
